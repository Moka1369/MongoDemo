@code
{
    private CreateCustomerRequest _model = new();
    private MudForm? _form;
    private bool _isSaving;
 
    private async Task Create()
    {
        await _form.Validate();

        if (!_form.IsValid) return;

        _isSaving = true;

        var ok = await CustomerApi.CreateAsync(_model);
        if (ok)
        {
            Snackbar.Add("Customer created successfully.", Severity.Success);
            Navigation.NavigateTo("/customers");
        }
        else
        {
            Snackbar.Add("Customer kann leider nicht gespeichert werden", Severity.Error);
        }
        _isSaving = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/customers");
    }

}