@page "/customers/create"
@using MongoDemo.Ui.Models
@using MongoDemo.Ui.Services
@using MudBlazor

@* @rendermode InteractiveServer *@

@inject NavigationManager Navigation
@inject CustomerApiService CustomerApi
@inject ISnackbar Snackbar

<PageTitle>Create Customer</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" class="mt-6">
    <MudCard Elevation="4">
        <MudCardHeader>
            <MudText Typo="Typo.h5">
                Create Customer
            </MudText>
        </MudCardHeader>
        <MudCardContent>
            <MudForm @ref="_form">
                <MudTextField Label="First Name" @bind-Value="_model.FirstName" Required="true"
                              RequiredError="FirstName ist erforderlich." />
                <MudTextField Label="Last Name" @bind-Value="_model.LastName" Required="true"
                              RequiredError="LastName ist erforderlich." Class="mt-3" />
                <MudTextField Label="Email" @bind-Value="_model.Email" Required="true"
                              RequiredError="Email ist erforderlich." Class="mt-3" />
            </MudForm>
        </MudCardContent>
        <MudCardActions Class="pa-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Create" Disabled="_isSaving">
                @(_isSaving ? "Saving..." : "Save")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="GoBack"> Cancel</MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>


@* <EditForm Model="_model" OnValidSubmit="Create">
    <DataAnnotationsValidator/>
    <ValidationSummary/>
    <div>
        <label>First Name:</label>
        <InputText class="form-control" @bind-Value="_model.FirstName" />
